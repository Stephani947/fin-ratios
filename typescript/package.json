{
  "name": "fin-ratios",
  "version": "0.9.0",
  "description": "The most comprehensive financial ratios library. 136+ ratios · 10 institutional-grade scoring models · TypeScript + Python · Valuation, Management, Dividend Safety, Investment Scores · FastAPI, MCP server, React hooks, EDGAR fetcher, Pandas/Polars · Zero runtime core dependencies.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fetchers/yahoo": {
      "types": "./dist/fetchers/yahoo/index.d.ts",
      "import": "./dist/fetchers/yahoo/index.js",
      "require": "./dist/fetchers/yahoo/index.cjs"
    },
    "./fetchers/fmp": {
      "types": "./dist/fetchers/fmp/index.d.ts",
      "import": "./dist/fetchers/fmp/index.js",
      "require": "./dist/fetchers/fmp/index.cjs"
    },
    "./fetchers/edgar": {
      "types": "./dist/fetchers/edgar/index.d.ts",
      "import": "./dist/fetchers/edgar/index.js",
      "require": "./dist/fetchers/edgar/index.cjs"
    },
    "./fetchers/alphavantage": {
      "types": "./dist/fetchers/alphavantage/index.d.ts",
      "import": "./dist/fetchers/alphavantage/index.js",
      "require": "./dist/fetchers/alphavantage/index.cjs"
    },
    "./fetchers/polygon": {
      "types": "./dist/fetchers/polygon/index.d.ts",
      "import": "./dist/fetchers/polygon/index.js",
      "require": "./dist/fetchers/polygon/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    }
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "keywords": [
    "finance",
    "financial-ratios",
    "valuation",
    "dcf",
    "sharpe-ratio",
    "piotroski",
    "altman-z-score",
    "beneish-m-score",
    "fintech",
    "investing",
    "typescript",
    "saas-metrics",
    "portfolio",
    "risk"
  ],
  "author": {
    "name": "Piyush Gupta",
    "url": "https://github.com/piyushgupta344"
  },
  "license": "MIT",
  "homepage": "https://github.com/piyushgupta344/fin-ratios#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piyushgupta344/fin-ratios.git"
  },
  "bugs": {
    "url": "https://github.com/piyushgupta344/fin-ratios/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
